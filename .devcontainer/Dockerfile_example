# Full personalized config can be generated with: dc-contain
# (alias from dev-control, built into this container)

FROM ubuntu:latest

ENV DEBIAN_FRONTEND=noninteractive

# Install tool development tools and dependencies
RUN apt-get update && apt-get upgrade -y && apt-get install -y \
    git \
    build-essential \
    sudo \
    locales \
    lsb-release \
    curl \
    ca-certificates \
    gnupg \
    libsecret-tools \
    nano \
    && sed -i 's|http://archive.ubuntu.com/ubuntu|YOUR_CLOSEST_UBUNTU_MIRROR|g' /etc/apt/sources.list.d/ubuntu.sources 2>/dev/null || \
       sed -i 's|http://archive.ubuntu.com/ubuntu|YOUR_CLOSEST_UBUNTU_MIRROR|g' /etc/apt/sources.list 2>/dev/null || true \
    && sed -i '/en_GB/s/^# //g' /etc/locale.gen \
    && locale-gen en_GB.UTF-8 \
    && update-locale LANG=en_GB.UTF-8 LC_ALL=en_GB.UTF-8 \
    && rm -rf /var/lib/apt/lists/*

# Set locale and timezone
ENV LANG=en_GB.UTF-8 \
    LC_ALL=en_GB.UTF-8 \
    TZ=YOUR_TIMEZONE \
    EDITOR=nano

# Configure timezone
RUN ln -snf /usr/share/zoneinfo/${TZ} /etc/localtime && echo ${TZ} > /etc/timezone

# Install GitHub CLI
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" > /etc/apt/sources.list.d/github-cli.list \
    && apt-get update && apt-get install -y gh wget \
    && rm -rf /var/lib/apt/lists/*

# Install CUDA Toolkit 13.1
RUN wget https://developer.download.nvidia.com/compute/cuda/repos/ubuntu2404/x86_64/cuda-keyring_1.1-1_all.deb -O /tmp/cuda-keyring.deb \
    && dpkg -i /tmp/cuda-keyring.deb \
    && rm -f /tmp/cuda-keyring.deb \
    && apt-get update && apt-get install -y --no-install-recommends \
        cuda-toolkit-13-1 \
        cuda-nvcc-13-1 \
        cuda-libraries-dev-13-1 \
        cuda-cudart-dev-13-1 \
    && rm -rf /var/lib/apt/lists/*

# Install CUDA 12.6 runtime libraries for ONNX Runtime 1.20.x compatibility
# (ONNX Runtime GPU binary is built against CUDA 12.x, not 13.x)
RUN apt-get update && apt-get install -y --no-install-recommends \
        cuda-cudart-12-6 \
        cuda-nvrtc-12-6 \
        libcublas-12-6 \
        libcufft-12-6 \
        libcurand-12-6 \
        libcusparse-12-6 \
        libcusolver-12-6 \
        libnvjitlink-12-6 \
        libcudnn9-cuda-12 \
    && rm -rf /var/lib/apt/lists/*

# Set CUDA environment variables (CUDA 13 for dev, but 12.6 runtime libs available for ONNX RT)
ENV PATH=/usr/local/cuda/bin:${PATH} \
    LD_LIBRARY_PATH=/usr/local/cuda-12.6/lib64:/usr/local/cuda/lib64:${LD_LIBRARY_PATH} \
    CUDA_HOME=/usr/local/cuda

# Create user vidcom with sudo privileges (rename ubuntu user which already has UID 1000)
RUN usermod -l vidcom -d /home/vidcom -m ubuntu && \
    groupmod -n vidcom ubuntu && \
    usermod -aG sudo vidcom && \
    echo "vidcom ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers && \
    mkdir -p /home/vidcom/.config /home/vidcom/.cache /home/vidcom/.local/share /home/vidcom/.gnupg && \
    chown -R 1000:1000 /home/vidcom && \
    chmod 755 /home/vidcom && \
    chmod 700 /home/vidcom/.gnupg

USER vidcom

ENV HOME=/home/vidcom \
    XDG_CONFIG_HOME=/home/vidcom/.config \
    XDG_CACHE_HOME=/home/vidcom/.cache \
    XDG_DATA_HOME=/home/vidcom/.local/share

WORKDIR /home/vidcom

RUN touch ~/.hushlogin

# Install nvm (latest), Node.js, and Dev-Control
ENV NVM_DIR=/home/vidcom/.config/nvm
ENV BASH_ENV=/home/vidcom/.bashrc
RUN export HOME=/home/vidcom && \
    mkdir -p "$NVM_DIR" && \
    NVM_LATEST=$(curl -fsSL https://api.github.com/repos/nvm-sh/nvm/releases/latest | grep -oP '"tag_name": "\K[^"]+') && \
    curl -o- "https://raw.githubusercontent.com/nvm-sh/nvm/${NVM_LATEST}/install.sh" | bash && \
    echo 'export NVM_DIR="$HOME/.config/nvm"' >> ~/.bashrc && \
    echo '[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"' >> ~/.bashrc && \
    bash -c 'source $NVM_DIR/nvm.sh && nvm install 25 && nvm alias default 25' && \
    curl -fsSL --retry 3 --retry-delay 5 https://github.com/xaoscience/dev-control/archive/refs/tags/latest.tar.gz | tar -xz && \
    mv dev-control-* ~/.dev-control && \
    bash -c 'bash ~/.dev-control/scripts/alias-loading.sh <<< A'

# Add node/npm/npx to PATH for VS Code extension host discovery
ENV PATH=$NVM_DIR/versions/node/v25.4.0/bin:$PATH

# Bake user-specific git config into image
RUN git config --global user.email YOUR_GITHUB_ID+YOUR_USERNAME@users.noreply.github.com && \
    git config --global user.name YOUR_USERNAME && \
    git config --global init.defaultBranch main && \
    git config --global commit.gpgsign true && \
    git config --global user.signingkey YOUR_GPG_KEY_ID && \
    git config --global gpg.program gpg

# Build FFmpeg from master with NVENC/NVDEC + SRT support (full CUDA)
RUN sudo apt-get update && sudo apt-get install -y \
    nasm yasm pkg-config gpg dirmngr \
    libmd0 \
    libx264-dev libx265-dev libvpx-dev \
    libfdk-aac-dev libmp3lame-dev libopus-dev \
    libass-dev libfreetype6-dev libvorbis-dev \
    libwebp-dev libaom-dev libdav1d-dev \
    librist-dev libssl-dev cmake \
    libzmq3-dev libsdl2-dev \
    && sudo rm -rf /var/lib/apt/lists/*

# Build SRT from source (not in Ubuntu 24.04 repos)
RUN git clone --depth 1 --branch v1.5.4 https://github.com/Haivision/srt.git /tmp/srt \
    && cd /tmp/srt \
    && cmake -B build -DCMAKE_INSTALL_PREFIX=/usr/local \
    && cmake --build build -j$(nproc) \
    && sudo cmake --install build \
    && rm -rf /tmp/srt \
    && sudo ldconfig

# Install nv-codec-headers for NVENC/NVDEC
RUN git clone --depth 1 https://github.com/FFmpeg/nv-codec-headers.git /tmp/nv-codec-headers \
    && cd /tmp/nv-codec-headers \
    && sudo make install \
    && rm -rf /tmp/nv-codec-headers

# FFmpeg: build from master HEAD with NVENC/NVDEC (uses driver at runtime)
RUN git clone --depth 1 https://git.ffmpeg.org/ffmpeg.git /tmp/ffmpeg \
    && cd /tmp/ffmpeg \
    && ./configure \
        --prefix=/usr/local \
        --enable-gpl --enable-nonfree \
        --enable-cuvid --enable-nvenc --enable-nvdec \
        --enable-libx264 --enable-libx265 \
        --enable-libvpx --enable-libfdk-aac \
        --enable-libmp3lame --enable-libopus \
        --enable-libass --enable-libfreetype \
        --enable-libwebp --enable-libaom \
        --enable-libdav1d \
        --enable-libsrt --enable-librist \
        --enable-libzmq \
    && make -j$(nproc) \
    && sudo make install \
    && rm -rf /tmp/ffmpeg

# Build NGINX mainline with RTMP module for streaming
# Import developer signing keys: https://nginx.org/en/pgp_keys.html
RUN sudo apt-get update && sudo apt-get install -y \
    libpcre3-dev libssl-dev zlib1g-dev \
    && sudo rm -rf /var/lib/apt/lists/* \
    && git clone --depth 1 https://github.com/arut/nginx-rtmp-module.git /tmp/nginx-rtmp \
    && curl -fsSL https://nginx.org/keys/nginx_signing.key | gpg --import \
    && curl -fsSL https://nginx.org/keys/pluknet.key | gpg --import \
    && curl -fsSL https://nginx.org/keys/arut.key | gpg --import \
    && curl -fsSL https://nginx.org/keys/sb.key | gpg --import \
    && curl -fsSL https://nginx.org/keys/thresh.key | gpg --import \
    && curl -sLO https://nginx.org/download/nginx-1.29.4.tar.gz \
    && curl -sLO https://nginx.org/download/nginx-1.29.4.tar.gz.asc \
    && gpg --verify nginx-1.29.4.tar.gz.asc nginx-1.29.4.tar.gz \
    && tar -xzf nginx-1.29.4.tar.gz -C /tmp \
    && rm -f nginx-1.29.4.tar.gz nginx-1.29.4.tar.gz.asc \
    && cd /tmp/nginx-1.29.4 \
    && ./configure \
        --prefix=/usr/local/nginx \
        --with-http_ssl_module \
        --with-http_v2_module \
        --with-http_realip_module \
        --with-http_stub_status_module \
        --with-stream \
        --with-stream_ssl_module \
        --add-module=/tmp/nginx-rtmp \
    && make -j$(nproc) \
    && sudo make install \
    && rm -rf /tmp/nginx-* \
    && sudo ln -sf /usr/local/nginx/sbin/nginx /usr/local/bin/nginx

# Install streaming utilities (split to avoid podman symlink exhaustion)
RUN sudo apt-get update && sudo apt-get install -y mediainfo && sudo rm -rf /var/lib/apt/lists/*
RUN sudo apt-get update && sudo apt-get install -y sox libsox-fmt-all && sudo rm -rf /var/lib/apt/lists/*
RUN sudo apt-get update && sudo apt-get install -y v4l-utils && sudo rm -rf /var/lib/apt/lists/*

# Install yt-dlp from source (standalone binary release)
RUN YT_DLP_VERSION=$(curl -s https://api.github.com/repos/yt-dlp/yt-dlp/releases/latest | grep -oP '"tag_name": "\K[^"]+') \
    && sudo curl -fsSL "https://github.com/yt-dlp/yt-dlp/releases/download/${YT_DLP_VERSION}/yt-dlp" -o /usr/local/bin/yt-dlp \
    && sudo chmod a+rx /usr/local/bin/yt-dlp \
    && yt-dlp --version

ENV PATH=/usr/local/nginx/sbin:$PATH

# ============================================
# VIDCOM: TensorRT + ONNX Runtime + Tools
# ============================================

# Install TensorRT from cuda-keyring repos (already added above)
RUN sudo apt-get update && sudo apt-get install -y \
    libnvinfer-lean10 \
    libnvinfer-vc-plugin10 \
    libnvinfer-dispatch10 \
    libnvinfer-headers-dev \
    bc \
    jq \
    sqlite3 \
    && sudo rm -rf /var/lib/apt/lists/*

# Install ONNX Runtime 1.20.1 pre-built GPU binary
RUN ONNX_VERSION="1.20.1" \
    && curl -fsSL "https://github.com/microsoft/onnxruntime/releases/download/v${ONNX_VERSION}/onnxruntime-linux-x64-gpu-${ONNX_VERSION}.tgz" -o /tmp/onnxruntime.tgz \
    && sudo tar -xzf /tmp/onnxruntime.tgz -C /opt \
    && sudo mv /opt/onnxruntime-linux-x64-gpu-${ONNX_VERSION} /opt/onnxruntime \
    && sudo ln -sf /opt/onnxruntime/include/* /usr/local/include/ \
    && sudo ln -sf /opt/onnxruntime/lib/libonnxruntime.so* /usr/local/lib/ \
    && sudo ln -sf /opt/onnxruntime/lib/libonnxruntime_providers_cuda.so /usr/local/lib/ \
    && sudo ln -sf /opt/onnxruntime/lib/libonnxruntime_providers_shared.so /usr/local/lib/ \
    && sudo ln -sf /opt/onnxruntime/lib/libonnxruntime_providers_cuda.so /usr/local/lib/ \
    && sudo ln -sf /opt/onnxruntime/lib/libonnxruntime_providers_shared.so /usr/local/lib/ \
    && sudo ldconfig \
    && rm -f /tmp/onnxruntime.tgz

# Set ONNX Runtime environment
ENV ONNXRUNTIME_DIR=/opt/onnxruntime
ENV LD_LIBRARY_PATH=/opt/onnxruntime/lib:${LD_LIBRARY_PATH}

# Create pkg-config for ONNX Runtime
RUN echo 'prefix=/usr/local' | sudo tee /usr/local/lib/pkgconfig/onnxruntime.pc \
    && echo 'exec_prefix=${prefix}' | sudo tee -a /usr/local/lib/pkgconfig/onnxruntime.pc \
    && echo 'includedir=${prefix}/include' | sudo tee -a /usr/local/lib/pkgconfig/onnxruntime.pc \
    && echo 'libdir=${prefix}/lib' | sudo tee -a /usr/local/lib/pkgconfig/onnxruntime.pc \
    && echo '' | sudo tee -a /usr/local/lib/pkgconfig/onnxruntime.pc \
    && echo 'Name: ONNX Runtime' | sudo tee -a /usr/local/lib/pkgconfig/onnxruntime.pc \
    && echo 'Description: ONNX Runtime inference engine' | sudo tee -a /usr/local/lib/pkgconfig/onnxruntime.pc \
    && echo 'Version: 1.20.1' | sudo tee -a /usr/local/lib/pkgconfig/onnxruntime.pc \
    && echo 'Cflags: -I${includedir}' | sudo tee -a /usr/local/lib/pkgconfig/onnxruntime.pc \
    && echo 'Libs: -L${libdir} -lonnxruntime' | sudo tee -a /usr/local/lib/pkgconfig/onnxruntime.pc

# Export YOLOv8n to ONNX format (build-time only, Python removed after)
# Uses a temporary venv to avoid polluting the system
# Skips if models already exist (e.g. from cache mount)
RUN if [ -f /opt/models/yolov8n.onnx ]; then \
        echo "ONNX model already exists, skipping export"; \
    else \
        sudo apt-get update && sudo apt-get install -y --no-install-recommends python3-pip python3-venv \
        && python3 -m venv /tmp/yolo-export \
        && /tmp/yolo-export/bin/pip install ultralytics onnx onnxslim onnxruntime \
        && cd /tmp/yolo-export \
        && if [ -f /opt/models/yolov8n.pt ]; then \
               echo "PT model exists, using cached version"; \
               cp /opt/models/yolov8n.pt yolov8n.pt; \
           fi \
        && /tmp/yolo-export/bin/python -c "from ultralytics import YOLO; model = YOLO('yolov8n.pt'); model.export(format='onnx', imgsz=640, opset=17, simplify=True)" \
        && sudo mkdir -p /opt/models \
        && sudo mv /tmp/yolo-export/yolov8n.onnx /opt/models/yolov8n.onnx \
        && sudo mv /tmp/yolo-export/yolov8n.pt /opt/models/yolov8n.pt 2>/dev/null || true \
        && sudo chmod 644 /opt/models/yolov8n.* \
        && rm -rf /tmp/yolo-export ~/.config/Ultralytics /tmp/Ultralytics \
        && sudo apt-get purge -y python3-pip python3-venv \
        && sudo apt-get autoremove -y \
        && sudo rm -rf /var/lib/apt/lists/*; \
    fi \
    && ls -lh /opt/models/

# Clean up GPG keyring created during nginx verification (interferes with host GPG agent mount)
RUN sudo rm -rf ~/.gnupg

WORKDIR /workspaces
